flowchart TD
    start([Job received from scan.jobs.v1]) --> parse[Parse JSON payload]
    parse --> validate{images list and\nscan-level imageType/bodyPart present?}
    validate -- no --> failJob[Build failed result payload]
    validate -- yes --> eachImage[Iterate over images]

    eachImage --> resolvePath[Resolve file path from filePath\nand storage.uploadsBasePath]
    resolvePath --> pathOk{File exists?}
    pathOk -- no --> imageError[Append image error]
    pathOk -- yes --> resolveModels[Resolve models from\nimageType + bodyPart + file path]

    resolveModels --> eachModel[Iterate over resolved models]
    eachModel --> loadModel[Load or reuse cached Keras model]
    loadModel --> preprocess[Resize + preprocess image]
    preprocess --> infer[Run TensorFlow inference]
    infer --> decode[Decode label, confidence, probabilities]
    decode --> imageResult[Append result entry with\nimageUuid, modelKey, routeKey]
    loadModel -. exception .-> modelError[Append model-specific error]
    preprocess -. exception .-> modelError
    infer -. exception .-> modelError
    decode -. exception .-> modelError

    imageError --> moreImages{More images?}
    imageResult --> moreModels{More models for image?}
    modelError --> moreModels
    moreModels -- yes --> eachModel
    moreModels -- no --> moreImages
    moreImages -- yes --> eachImage
    moreImages -- no --> summarize[Build results object\nimages, errors, count, failedCount, total]

    summarize --> hasSuccess{count > 0?}
    hasSuccess -- yes --> successPayload[Build completed scan.result.v1 payload]
    hasSuccess -- no --> failJob
    successPayload --> publish[Publish to scan.results.v1]
    failJob --> publish
    publish --> ack[Acknowledge job]
    ack --> done([Wait for next message])
