flowchart LR
    patient[Patient]
    doctor[Doctor]

    subgraph product[Medical AI Platform]
        frontend[Frontend\nReact Router + Vite]
        backend[Backend API\nNode.js + Express]
        consumer[AI Consumer\nPython + TensorFlow]
    end

    subgraph infrastructure[Infrastructure]
        db[(SQLite or PostgreSQL)]
        mq[(RabbitMQ)]
        uploads[(Shared uploads storage)]
        models[(Keras model files)]
    end

    push[Web Push Service]

    patient -->|authenticate, book, upload scans, view results, read blog| frontend
    doctor -->|manage appointments, add diagnoses and follow-up dates, view profile| frontend
    frontend -->|REST API + Bearer token| backend
    backend -->|persist entities| db
    backend -->|write uploaded files| uploads
    backend -->|publish scan jobs| mq
    mq -->|deliver scan jobs| consumer
    consumer -->|read image files| uploads
    consumer -->|load models| models
    consumer -->|publish scan results| mq
    mq -->|deliver result events| backend
    backend -->|create notifications| db
    backend -->|send push payloads| push
    push -->|browser notifications| patient
