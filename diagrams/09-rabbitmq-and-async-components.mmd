flowchart LR
    subgraph backend[Backend async subsystems]
        scanService[scan-service\npublishScanJob]
        rabbitService[rabbitmq-service\nconnect + assert infra + consume]
        scanResultService[scan-result-service\napplyScanResult]
        scheduler[startSchedulers\ncron 0 9 * * *]
        followUp[follow-up-reminder-service]
        notificationService[notification-service]
        pushService[web-push-service]
    end

    subgraph broker[RabbitMQ]
        jobs[scan.jobs.v1]
        results[scan.results.v1]
        dlx[scan.dlx]
        jobsDlq[scan.jobs.v1.dlq]
        resultsDlq[scan.results.v1.dlq]
    end

    subgraph worker[Python consumer]
        workerLoop[run_worker]
        processing[process_scan_job]
    end

    scanService --> rabbitService
    rabbitService --> jobs
    jobs --> workerLoop --> processing
    processing --> results
    results --> rabbitService --> scanResultService
    scanResultService --> notificationService --> pushService
    scheduler --> followUp --> notificationService

    jobs -. dead-letter .-> dlx --> jobsDlq
    results -. dead-letter .-> dlx --> resultsDlq
